{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://coop.dev/schemas/memory-store.v1.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "type": "string", "pattern": "^coop\\.dev/v\\d+$" },
    "description": { "type": "string" },
    "scope": { "enum": ["agent", "team", "project"] },
    "retention": { "type": "string", "pattern": "^\\d+(d|w|mo|y)$" }
  }
}
